# Global options
{
	metrics {
		per_host
	}
}

(strip_headers) {
	# Strip internal headers used by Wikijump
	request_header -X-Wikijump-*
}

#
# MAIN
#

(serve_main) {
	# Special routes
	respond /-/teapot '🫖' 418

	# wjfiles-managed routes
	# These are proxied to wws for it to handle, but shouldn't be redirected
	@proxy {
		path /robots.txt
		path /.well-known
		path /-/health-check
	}
	request_header @proxy X-Wikijump-Target-Server main
	reverse_proxy @proxy {vars.site_slug}.wjfiles.test{uri}

	# Redirect, true route is on the files server
	@redirect {
		path /*/code/*
		path /*/html/*
		path /*/file/*  # for the /{slug}/file/{filename} convenience routes
		path /*/download/*
		path /local--files/*
		path /local--code/*
		path /local--html/*
		path /-/files/*
		path /-/file/*
		path /-/download/*
		path /-/code/*
		path /-/html/*
	}
	redir @redirect https://{vars.site_slug}.wjfiles.test{uri}

	# Enable default compression settings
	encode

	# Finally, proxy to framerail to get the actual HTML
	# Note, the x-wikijump-site-* headers have already been set at this point
	reverse_proxy web_proxy_host
}

foo.wikijump.test {
	import strip_headers

	vars {
		site_id 1
		site_slug foo
	}

	request_header X-Wikijump-Site-Id {vars.site_id}
	request_header X-Wikijump-Site-Slug {vars.site_slug}

	import serve_main
}

www.foo.wikijump.test {
	redir https://foo.wikijump.test{uri}
}

bar.wikijump.test,
www.bar.wikijump.test {
	redir https://example.com{uri}
}

example.com {
	import strip_headers

	vars {
		site_id 2
		site_slug bar
	}

	request_header X-Wikijump-Site-Id {vars.site_id}
	request_header X-Wikijump-Site-Slug {vars.site_slug}

	import serve_main
}

www.example.com {
	redir https://example.com{uri}
}

#
# FILES
#

(serve_files) {
	import strip_headers
	encode
	respond /-/teapot '🫖' 418
	request_header X-Wikijump-Target-Server files
	reverse_proxy wws_proxy_host
}

wjfiles.test {
	request_header X-Wikijump-Special-Error 1
	rewrite * /-/special-error/file-root
	reverse_proxy wws_proxy_host
}

*.wjfiles.test {
	import strip_headers

	@foo host foo.wjfiles.test
	vars @foo site_id 1

	@bar host bar.wjfiles.test
	vars @bar site_id 2

	request_header X-Wikijump-Site-Slug {labels.2}
	request_header X-Wikijump-Site-Id {vars.site_id}

	import serve_files
}

#
# FALLBACK
# (i.e. "no such site")
#

# Missing canonical domain
*.wikijump.test {
	import strip_headers
	request_header X-Wikijump-Special-Error 1
	request_header X-Wikijump-Site-Slug {labels.2}
	rewrite * /-/special-error/site-slug
	reverse_proxy wws_proxy_host
}

# Missing custom domain
http://,
https:// {
	import strip_headers
	request_header X-Wikijump-Special-Error 1
	rewrite * /-/special-error/site-custom
	reverse_proxy wws_proxy_host
}

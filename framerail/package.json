{
  "name": "framerail",
  "version": "2026.1.18",
  "description": "Framerail - Wikijump frontend service",
  "repository": "https://github.com/scpwiki/wikijump/tree/develop/framerail",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint . && stylelint ./src/**/*.{css,scss,svelte}",
    "lint:fix": "prettier --write . && eslint . --fix && stylelint ./src/**/*.{css,scss,svelte} --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/accept-language-parser": "^1.5.8",
    "@types/node": "^24.10.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "postcss": "^8.5.6",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.0",
    "sass": "^1.93.3",
    "stylelint": "^16.25.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.14.0",
    "svelte-eslint-parser": "^1.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.3.3",
    "@sveltejs/kit": "^2.27.3",
    "accept-language-parser": "^1.5.0",
    "json-rpc-2.0": "^1.7.1",
    "svelte": "^4.2.20",
    "svelte-check": "^4.3.4",
    "svelte-preprocess": "^6.0.3",
    "tslib": "^2.8.1",
    "vite": "^5.4.21"
  }

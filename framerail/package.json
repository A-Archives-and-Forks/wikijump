    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint . && stylelint ./src/**/*.{css,scss,svelte}",
    "lint:fix": "prettier --write . && eslint . --fix && stylelint ./src/**/*.{css,scss,svelte} --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
